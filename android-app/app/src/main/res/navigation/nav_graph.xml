<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/feedFragment">

    <fragment
        android:id="@+id/feedFragment"
        android:name="com.foodbook.fragments.FeedFragment"
        android:label="Feed"
        tools:layout="@layout/fragment_feed" />

    <fragment
        android:id="@+id/searchFragment"
        android:name="com.foodbook.fragments.SearchFragment"
        android:label="Pesquisar"
        tools:layout="@layout/fragment_search" />

    <fragment
        android:id="@+id/profileFragment"
        android:name="com.foodbook.fragments.ProfileFragment"
        android:label="Perfil"
        tools:layout="@layout/fragment_profile" />

    <fragment
        android:id="@+id/favoritesFragment"
        android:name="com.foodbook.fragments.FavoritesFragment"
        android:label="Favoritos"
        tools:layout="@layout/fragment_favorites" />

    <fragment
        android:id="@+id/shoppingListFragment"
        android:name="com.foodbook.fragments.ShoppingListFragment"
        android:label="Lista de Compras"
        tools:layout="@layout/fragment_shopping_list" />

    <fragment
        android:id="@+id/recipeDetailFragment"
        android:name="com.foodbook.fragments.RecipeDetailFragment"
        android:label="Detalhes"
        tools:layout="@layout/fragment_recipe_detail">
        <argument
            android:name="recipeId"
            app:argType="long" />
    </fragment>

    <fragment
        android:id="@+id/recipeFormFragment"
        android:name="com.foodbook.fragments.RecipeFormFragment"
        android:label="Nova Receita"
        tools:layout="@layout/fragment_recipe_form">
        <argument
            android:name="recipeId"
            app:argType="long"
            android:defaultValue="-1" />
    </fragment>

</navigation>
